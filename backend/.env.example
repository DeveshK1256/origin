FLASK_DEBUG=1
PORT=5000
CORS_ORIGINS=http://localhost:5173

# Database mode: auto | supabase | local
DATABASE_BACKEND=auto
# Optional local fallback directory for JSONL storage
DATABASE_DIR=backend/data
# When true, write to local storage if Supabase insert/read fails
SUPABASE_FALLBACK_LOCAL=1

# Supabase project settings (backend/server)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth mode: auto | required | optional | off
AUTH_MODE=auto

# Job data provider (Adzuna API)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
ADZUNA_LOCATION=United States
# Set to 1 only when you explicitly need environment proxy variables for outbound requests.
JOB_REQUEST_TRUST_ENV=0

# Hugging Face inference API for fake-job model (optional)
HF_API_TOKEN=
HF_FAKE_JOB_MODEL_ID=
HF_TIMEOUT_SECONDS=12
